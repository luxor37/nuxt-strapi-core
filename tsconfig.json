{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "baseUrl": "."
  },
  "include": [
    "src/**/*.ts",
    "playgrounds/**/*.ts",
    "test/**/*.ts"
  ]
}
